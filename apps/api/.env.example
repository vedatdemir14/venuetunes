# Sunucu
PORT=3000

# Veritabanı (docker-compose ile uyumlu)
DATABASE_URL=postgresql://venuetunes:dev_password@localhost:5432/venuetunes

# Redis (Faz 1'de kullanılacak)
REDIS_URL=redis://localhost:6379

# JWT (misafir/admin oturumları — Faz 1)
JWT_SECRET=degistir_bunu

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/spotify/callback

# Refresh token şifreleme anahtarı (32 byte hex)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
